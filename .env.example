PORT=3000

# Base path untuk semua route API (optional)
# Contoh: /api  → endpoint menjadi /api/users
API_BASE_PATH=/api

# Direktori mock data relatif terhadap root project
# Default di README: src/mocks
MOCK_DATA_DIR=src/mocks

# Aktifkan file watcher untuk auto-reload routes
ENABLE_FILE_WATCHER=true

# Environment node (development | production)
NODE_ENV=development
